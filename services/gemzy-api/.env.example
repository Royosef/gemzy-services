DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional if you want anon-key-backed server helpers instead of falling back
# to the service key.
SUPABASE_ANON_KEY=

GENERATION_SERVER_URL=
GENERATION_SHARED_SECRET=
GENERATION_CALLBACK_URL=

# Dashboard/browser origin allowlist for FastAPI CORS.
# Local example: http://localhost:5173
CORS_ORIGINS=

GCS_SIGNING_SERVICE_ACCOUNT=
GCS_COLLECTIONS_PUBLIC_BUCKET=public.gemzy.co
GCS_COLLECTIONS_APP_BUCKET=app.gemzy.co
GCS_UPLOAD_URL_TTL=900
GCS_UPLOAD_MAX_BYTES=26214400
GCS_PROJECT=

GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=

# RevenueCat envs used by the existing payments/subscriptions routes.
RC_WEBHOOK_AUTH=
RC_SECRET_KEY=
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=
# Legacy dashboard/browser alias still accepted by dashboard_revenue.py as a
# compatibility fallback, but REVENUECAT_PROJECT_ID is the canonical server env.
# VITE_REVENUECAT_PROJECT_ID=

# Dashboard/public webhook secrets used by the migrated dashboard automation
# routes in /api/webhooks/*.
REVENUECAT_WEBHOOK_SECRET=
AUTH_SIGNUP_WEBHOOK_SECRET=

# Dashboard email sending and tracking.
GMAIL_SMTP_USER=
GMAIL_SMTP_PASSWORD=
GMAIL_SMTP_FROM_ADDRESS=
GMAIL_SMTP_FROM_NAME=Gemzy
PUBLIC_DASHBOARD_URL=

# Dashboard marketing/ads sync.
# Values must be unquoted.
META_SYSTEM_USER_TOKEN=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
TAVILY_API_KEY=

# Legacy dashboard envs kept here for parity tracking / future reinstatement.
# The restored TypeScript dashboard server carried these, but the current
# gemzy-api code path does not actively read them yet.
META_APP_ID=
META_APP_SECRET=
POSTHOG_API_KEY=

# Dashboard AI helpers (rewrite / coach / funnel flows).
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com
DASHBOARD_CLAUDE_MODEL=claude-opus-4-7

SENTRY_DSN=
LOG_FORMAT=json
APP_ENV=development

# Optional avatar storage config used by auth/profile flows.
# GCS_AVATARS_BUCKET=
# GCS_AVATARS_PUBLIC_HOST=
# GCS_AVATARS_CACHE_CONTROL=
# GCS_AVATARS_MAX_BYTES=2097152
# GCS_OWNER_METADATA_KEY=appUserId

# Optional collection/view tuning.
# GCS_VIEW_URL_TTL=900
# GCS_COLLECTIONS_CACHE_CONTROL=
# DEFAULT_UNSAVED_COLLECTION_NAME=Unsaved
# LEGACY_UNSAVED_COLLECTION_NAMES=Unsaved

# Optional generation tuning.
# GENERATION_SERVER_ENDPOINT=/generate
# GENERATION_SERVER_TIMEOUT=30

# Optional RevenueCat API override.
# REVENUECAT_API_BASE=https://api.revenuecat.com

# Optional lifecycle/admin tuning.
# PLAN_CREDITS_CACHE_TTL=300
# PLAN_DEFAULT_INITIAL_CREDITS=0
# CREDIT_RESET_POLL_SECONDS=3600
# USER_DELETION_POLL_SECONDS=
# USER_DELETION_GRACE_DAYS=
# USER_DELETION_TABLE=user_deletion_queue

# Optional GCS inline credentials JSON.
# GCS_CREDENTIALS=

# Legacy / future optional integrations.
# GCS_PUBLIC_HOST=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# STRIPE_SUCCESS_URL=
# STRIPE_CANCEL_URL=
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=
